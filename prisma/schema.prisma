generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model order_items {
  id         Int       @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  price      Decimal   @db.Decimal(10, 2)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  orders     orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model orders {
  id             Int           @id @default(autoincrement())
  user_id        Int?
  total_amount   Decimal       @db.Decimal(10, 2)
  vat_amount     Decimal       @db.Decimal(10, 2)
  payment_method String?       @db.VarChar(100)
  status         String?       @default("completed") @db.VarChar(50)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  order_items    order_items[]
  users          users?        @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model products {
  id             Int           @id @default(autoincrement())
  title          String        @db.VarChar(255)
  description    String?
  price          Decimal       @db.Decimal(10, 2)
  size           String        @db.VarChar(50)
  color          String?       @db.VarChar(100)
  fabric_type    String?       @db.VarChar(100)
  quantity       Int           @default(0)
  image_url      String?
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  title_en       String?       @db.VarChar(255)
  description_en String?
  fabric_type_en String?       @db.VarChar(100)
  color_en       String?       @db.VarChar(100)
  style          String?       @db.VarChar(100)
  style_en       String?       @db.VarChar(100)
  barcode        String?       @db.VarChar(100)
  order_items    order_items[]
}

model users {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  email       String    @unique @db.VarChar(100)
  password    String
  role        String?   @default("customer") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  profile_pic String?   @default("") @db.VarChar(500)
  orders      orders[]
}
